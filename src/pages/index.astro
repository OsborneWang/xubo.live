---
import HeroSection from '../components/HeroSection.astro';
import NowPanel from '../components/NowPanel.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import LifeLog from '../components/LifeLog.astro';
import FooterLinks from '../components/FooterLinks.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Xubo 的个人数字名片、极客生活流与服务入口。" />
    <title>Xubo｜个人名片与生活流</title>
  </head>
  <body>
    <main class="page-shell" aria-label="Xubo 个人名片与生活流">
      <HeroSection />
      <NowPanel />
      <ServicesGrid />
      <LifeLog />
      <FooterLinks />
    </main>
    <script>
      const timeNode = document.querySelector('#local-time');

      function updateLocalTime() {
        if (!timeNode) return;

        const formatter = new Intl.DateTimeFormat('zh-CN', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          hour12: false,
        });

        timeNode.textContent = formatter.format(new Date());
      }

      updateLocalTime();
      window.setInterval(updateLocalTime, 1000);
    </script>
  </body>
</html>
