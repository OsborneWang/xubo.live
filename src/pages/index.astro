---
import HeroSection from '../components/HeroSection.astro';
import NowPanel from '../components/NowPanel.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import LifeLog from '../components/LifeLog.astro';
import FooterLinks from '../components/FooterLinks.astro';
import ThemeInit from '../components/ThemeInit.astro';
import PageScripts from '../components/PageScripts.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Xubo 的个人数字名片、极客生活流与服务入口。" />
    <ThemeInit />
    <title>Xubo｜个人名片与生活流</title>
  </head>
  <body>
    <main class="page-shell" aria-label="Xubo 个人名片与生活流">
      <HeroSection />
      <NowPanel />
      <ServicesGrid />
      <LifeLog />
      <FooterLinks />
    </main>
    <PageScripts />
  </body>
</html>
